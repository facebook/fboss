load("//fbpkg:fbpkg.bzl", "fbpkg")

oncall("fboss_optics_phy")

fbpkg.builder(
    name = "neteng.fboss.led_service",
    expire_days = 28,
    path_actions = {
        "led_service": "//fboss/led_service:led_service",
        "led_service.service": "led_service.service",
        # Descriptor-backed platform mappings, loaded at runtime via
        # --platform_descriptor_config_path for platforms whose mapping is no
        # longer compiled into the binary (e.g. wedge800bact).
        "platform_descriptors": fbpkg.copy("//fboss/lib/platform_mapping_v2/generated_platform_mappings:vendor_platform_descriptors"),
    },
    split_debuginfo = True,
)

fbpkg.builder(
    name = "neteng.fboss.led_service.test_artifacts",
    expire_days = 28,
    path_actions = {
        "led_service_hw_test": "//fboss/led_service/hw_test:led_service_hw_test",
        "platform_descriptors": fbpkg.copy("//fboss/lib/platform_mapping_v2/generated_platform_mappings:vendor_platform_descriptors"),
    },
    split_debuginfo = True,
)
