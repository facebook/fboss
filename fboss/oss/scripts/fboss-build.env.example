# Site-specific build configuration for FBOSS.
# Copy this file to fboss-build.env and set values for your infrastructure.
# fboss-build.env is gitignored and will not be committed.

# HTTP cache for getdeps dependency tarballs.
# Leave empty to build all deps from source (slower but always works).
# Example: http://your-cache-server:9090/getdeps-cache
GETDEPS_CACHE_URL=""

# Distributed sccache scheduler hostname.
# Leave empty to skip distributed compilation (local builds only).
# Example: sccache.your-domain.com
SCCACHE_SCHEDULER_HOST=""

# Auth token for the sccache distributed scheduler.
SCCACHE_AUTH_TOKEN=""

# Extra key-value pairs appended to the [dist] section of sccache-dist.toml.
# Use this to enable site-specific sccache knobs, e.g.:
#   SCCACHE_EXTRA_DIST_CONFIG="remote_only = true"
# "remote_only = true" is a Nexthop-internal sccache extension that prevents
# local fallback when the distributed farm is saturated.
SCCACHE_EXTRA_DIST_CONFIG=""

# Bazel remote cache URL.
# Leave empty for local-only caching.
# Example: http://your-bazel-remote:9090
BAZEL_REMOTE_CACHE_URL=""
