{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://www.internalfb.com/code/fbsource/fbcode/fboss/platform/firmware_onboarding/schemas/platform-spec.v1.json",
  "title": "FBOSS Platform Firmware Onboarding Spec",
  "description": "Tier-1 (structural) validation. See vendor-spec-schema.md for the human-readable contract. Cross-field semantic validation lives in the Pydantic models under fbcode/fboss/platform/firmware_onboarding/validator/ (added in a follow-up diff in this stack).",
  "type": "object",
  "required": ["spec_version", "platform", "components"],
  "additionalProperties": false,
  "properties": {
    "spec_version": {
      "const": "1.0"
    },
    "platform": {
      "type": "object",
      "required": ["name", "silicon"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "silicon": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "pcie_address"],
            "additionalProperties": false,
            "properties": {
              "name": {"type": "string", "minLength": 1},
              "pcie_address": {
                "type": "string",
                "pattern": "^[0-9a-f]{2}:[0-9a-f]{2}\\.[0-7]$"
              }
            }
          }
        }
      }
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/component"}
    },
    "_review_notes": {
      "type": "array",
      "items": {"type": "string"}
    }
  },
  "$defs": {
    "component": {
      "type": "object",
      "required": [
        "name",
        "location",
        "display_location",
        "field_replaceable",
        "firmware"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "platform_identifier": {
          "type": "string",
          "minLength": 1
        },
        "location": {
          "type": "string",
          "minLength": 1
        },
        "display_location": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "field_replaceable": {
          "type": "boolean"
        },
        "instances": {
          "type": "object",
          "required": ["range", "position"],
          "additionalProperties": false,
          "properties": {
            "range": {
              "type": "string",
              "pattern": "^[1-9][0-9]*-[1-9][0-9]*$"
            },
            "position": {
              "enum": ["at_end", "before_first_underscore"]
            }
          }
        },
        "pcie_address": {
          "oneOf": [
            {
              "type": "string",
              "pattern": "^[0-9a-f]{2}:[0-9a-f]{2}\\.[0-7]$"
            },
            {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "pattern": "^[0-9a-f]{2}:[0-9a-f]{2}\\.[0-7]$"
              }
            }
          ]
        },
        "firmware": {
          "type": "object",
          "required": ["priority", "shared_with_platforms"],
          "additionalProperties": false,
          "properties": {
            "priority": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            },
            "shared_with_platforms": {
              "type": "array",
              "items": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"}
            }
          }
        }
      }
    }
  }
}
